# Copy to `terraform.tfvars` (not committed) and fill in. Prefer TF_VAR_db_app_password in the environment.

aws_region        = "us-east-1"
project           = "nutriconsultas"

# Common free/tiny sizes (two instances may exceed 750h combined free tier).
db_instance_type  = "t3.micro"
app_instance_type = "t3.small"
ebs_root_volume_size_gb = 30

# Database and user created by the first-boot script on the DB host.
# db_name        = "nutriconsultas"
# db_app_username = "nutriapp"
# Set the password via environment, not in this file if you can avoid it:
#   export TF_VAR_db_app_password='...'
# or uncomment:
# db_app_password = "use-only-for-local-experiments"

# App secrets (written to /opt/nutriconsultas/app.env on first boot). Prefer environment:
#   export TF_VAR_auth_client='...' TF_VAR_auth_secret='...' TF_VAR_auth_issuer='https://.../'
#   export TF_VAR_auth_audience='https://api.example.com/mobile'
#   export TF_VAR_aws_bucket='...' TF_VAR_aws_key='...' TF_VAR_aws_secret='...'
# Optional (empty string ok if unused):
#   export TF_VAR_maps_key='' TF_VAR_recaptcha_secret_key='' TF_VAR_recaptcha_site_key=''
# auth_client            = "from-auth0-application"
# auth_secret            = "from-auth0-application"
# auth_issuer            = "https://YOUR_TENANT.auth0.com/"
# auth_audience          = "https://api.example.com/mobile"   # Auth0 API identifier; must match mobile AUTH0_AUDIENCE
# auth0_mgmt_client_id     = "from-auth0-m2m-app"   # M2M app with read:users on Management API (#109)
# auth0_mgmt_client_secret = "from-auth0-m2m-app"
# auth0_mgmt_domain        = ""   # optional; defaults to auth_issuer when empty
# aws_bucket             = "your-s3-bucket"   # Terraform creates this bucket; import if it already exists
# aws_key                = "AKIA..."
# aws_secret             = "..."
# maps_key               = ""
# recaptcha_secret_key   = "6L..."   # Google reCAPTCHA v2 secret
# recaptcha_site_key     = "6L..."   # Google reCAPTCHA v2 site key (public widget key)
#
# Platform admins (OAuth login emails; contact inquiries inbox). Gitignored tfvars only:
# platform_admin_emails = ["you@example.com", "colleague@example.com"]
#
# Stripe payment (#207). Prefer TF_VAR_stripe_secret_key / TF_VAR_stripe_webhook_secret in CI:
# payment_provider      = "stripe"
# stripe_secret_key     = "sk_test_..."
# stripe_webhook_secret = "whsec_..."   # optional until Stripe Dashboard webhook (#208)
#
# Security: EC2 user_data is readable via DescribeInstances; Terraform state also holds
# these values. For production, consider SSM SecureString / Secrets Manager instead.

# HTTPS (Let's Encrypt on the app EC2). Point DNS A/AAAA for each name to terraform output app_public_ip first.
# public_site_domain             = "minutriporcion.com"
# public_site_domain_aliases     = ["www.minutriporcion.com"]
# certbot_admin_email             = "you@example.com"

# Optional: create Route 53 hosted zone + A records to the app’s Elastic IP (~$0.50/mo per zone).
# If null, you can still point DNS at the EIP at your registrar; see domain-setup.md.
# route53_domain   = "minutriporcion.com"
# route53_www_record = true
#
# Invitation email via Amazon SES (#209). Requires a public mail domain (route53_domain or public_site_domain).
# enable_ses            = true
# ses_mail_domain       = "minutriporcion.com"
# invitation_mail_from  = "invites@minutriporcion.com"

# CodePipeline (CodeStar → GitHub → CodeBuild → SSM deploy). OMITTING github_repository
# (or leaving it as "") means Terraform will NOT create CodePipeline, CodeBuild, or a CodeStar
# connection — list-pipelines will be empty. Set a real org/repo, then `terraform apply`.
# github_repository   = "your-github-org/nutriconsultas"
# codepipeline_branch   = "main"   # branch that triggers the pipeline
