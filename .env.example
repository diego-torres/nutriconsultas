# Database Configuration
# These values are used by docker-compose.yml to initialize the PostgreSQL database
POSTGRES_DB=nutriconsultas
POSTGRES_USER=nutriconsultas
POSTGRES_PASSWORD=nutriconsultas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JDBC Connection String (for Spring Boot)
# These values are used by the Spring Boot application to connect to the database
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/nutriconsultas
JDBC_DATABASE_USERNAME=nutriconsultas
JDBC_DATABASE_PASSWORD=nutriconsultas
RECAPTCHA_SECRET_KEY=secretkey

# Optional: Maps API Key (if using maps functionality)
# MAPS_KEY=your_maps_key_here

# Optional: AWS S3 Configuration (if using S3 for file storage)
# AWS_BUCKET=your_bucket_name
# AWS_KEY=your_aws_access_key
# AWS_SECRET=your_aws_secret_key

# Auth0 OAuth2 — nutritionist web login (Regular Web Application)
# AUTH_CLIENT=your_auth0_client_id
# AUTH_SECRET=your_auth0_client_secret
# AUTH_ISSUER=https://your-domain.auth0.com/
# Patient mobile API JWT audience (Auth0 API identifier — required for /rest/mobile/**; see issue #108)
# Must match mobile AUTH0_AUDIENCE exactly.
# AUTH_AUDIENCE=https://api.nutriconsultas.minutriporcion.com

# Auth0 Management API — optional; enables nutritionist to link patient mobile accounts by email (#109)
# Create a Machine-to-Machine app with read:users scope on the Auth0 tenant.
# AUTH0_MGMT_CLIENT_ID=your_m2m_client_id
# AUTH0_MGMT_CLIENT_SECRET=your_m2m_client_secret
# AUTH0_MGMT_DOMAIN=https://your-domain.auth0.com/   # defaults to AUTH_ISSUER when omitted
