# Database Configuration
# These values are used by docker-compose.yml to initialize the PostgreSQL database
POSTGRES_DB=nutriconsultas
POSTGRES_USER=nutriconsultas
POSTGRES_PASSWORD=nutriconsultas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JDBC Connection String (for Spring Boot)
# These values are used by the Spring Boot application to connect to the database
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/nutriconsultas
JDBC_DATABASE_USERNAME=nutriconsultas
JDBC_DATABASE_PASSWORD=nutriconsultas
# Local dev: omit both vars to use Google test keys (application.properties defaults), or set
# production keys from https://www.google.com/recaptcha/admin for minutriporcion.com
# RECAPTCHA_SECRET_KEY=EXAMPLE_recaptcha_secret_for_local_dev
# RECAPTCHA_SITE_KEY=EXAMPLE_recaptcha_site_key_for_local_dev

# Optional: Maps API Key (if using maps functionality)
# MAPS_KEY=your_maps_key_here

# Optional: AWS S3 Configuration (if using S3 for file storage)
# AWS_BUCKET=your_bucket_name
# AWS_KEY=your_aws_access_key
# AWS_SECRET=your_aws_secret_key

# Auth0 OAuth2 — nutritionist web login (Regular Web Application)
# AUTH_CLIENT=your_auth0_client_id
# AUTH_SECRET=your_auth0_client_secret
# AUTH_ISSUER=https://your-domain.auth0.com/
# Patient mobile API JWT audience (Auth0 API identifier — required for /rest/mobile/**; see issue #108)
# Must match mobile AUTH0_AUDIENCE exactly.
# AUTH_AUDIENCE=https://api.nutriconsultas.minutriporcion.com

# Auth0 Management API — optional; patient email lookup (#109) and plan role sync (#182).
# M2M app scopes: read:users, read:roles, update:users, create:role_members, delete:role_members.
# See docs/subscription/AUTH0-ROLE-SYNC.md.
# AUTH0_MGMT_CLIENT_ID=your_m2m_client_id
# AUTH0_MGMT_CLIENT_SECRET=your_m2m_client_secret
# AUTH0_MGMT_DOMAIN=https://your-domain.auth0.com/   # defaults to AUTH_ISSUER when omitted

# Patient mobile auth broker — confidential Auth0 app (Password grant enabled server-side only).
# AUTH0_MOBILE_NATIVE_CLIENT_ID=CmZdUaMZ...   # same Native client id as the Flutter app
# AUTH0_PATIENT_BROKER_CLIENT_ID=your_confidential_broker_client_id
# AUTH0_PATIENT_BROKER_CLIENT_SECRET=your_confidential_broker_client_secret
# AUTH0_PATIENT_BROKER_DOMAIN=https://your-domain.auth0.com/   # optional; defaults to AUTH_ISSUER
# AUTH0_PATIENT_BROKER_CONNECTION=Username-Password-Authentication
# Grant M2M app Management API scopes: read:users (email lookup), read:connections + update:connections
# (disable public signup: infrastructure/scripts/auth0-disable-public-signup.sh), plus role sync scopes in docs/subscription/AUTH0-ROLE-SYNC.md

# Platform admins (OAuth login email → /admin/platform/**; comma-separated)
# PLATFORM_ADMIN_EMAILS=admin-one@example.com,admin-two@example.com

# Stripe payment (#207) — secret key required for live checkout; webhook secret after Dashboard setup (#208)
# PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=http://localhost:3000/admin
# STRIPE_CANCEL_URL=http://localhost:3000/admin

# OpenAI — AI Nutrition Assistant (#365); keep AI_ENABLED=false until OpenAI keys are set
# AI_ENABLED=false
# OPENAI_API_KEY=sk-proj-your_openai_api_key_here
# OPEN_API_KEY=sk-proj-legacy_alias_same_as_openai_api_key
# OPENAI_MODEL=gpt-5.5
# OPENAI_STORE=false
# AI_MAX_TOOL_CALLS=8
